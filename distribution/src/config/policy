grant {
  // Socket permissions for all local addresses and ports
  permission java.net.SocketPermission "localhost:1-65535", "accept,connect,listen,resolve";
  permission java.net.SocketPermission "127.0.0.1:1-65535", "accept,connect,listen,resolve";
  permission java.net.SocketPermission "[::1]:1-65535", "accept,connect,listen,resolve";
  permission java.net.SocketPermission "[0:0:0:0:0:0:0:1]:1-65535", "accept,connect,listen,resolve";

  // If needed, add permissions for specific ports
  permission java.net.SocketPermission "127.0.0.1:9200", "accept,connect,listen,resolve";
  permission java.net.SocketPermission "127.0.0.1:9300", "accept,connect,listen,resolve";

  // For development, you might want to add broader permissions
  permission java.net.SocketPermission "*:*", "accept,connect,listen,resolve";

   permission java.lang.RuntimePermission "setContextClassLoader";
  permission java.lang.RuntimePermission "getClassLoader";
  permission java.lang.RuntimePermission "accessClassInPackage.sun.misc";
  permission java.lang.RuntimePermission "accessDeclaredMembers";

  // If needed, add these as well
  permission java.lang.reflect.ReflectPermission "suppressAccessChecks";
  permission java.io.FilePermission "<<ALL FILES>>", "read,write";
  permission java.util.PropertyPermission "*", "read,write";

  permission java.lang.RuntimePermission "shutdownHooks";

   permission java.util.PropertyPermission "java.vm.version", "read";
    permission java.util.PropertyPermission "java.vm.vendor", "read";
    permission java.util.PropertyPermission "java.vm.name", "read";
    permission "java.io.FilePermission" "/var/tmp/killProfiler", "read,write";
    permission "java.io.FilePermission" "/home/-", "read,write";
    permission java.net.SocketPermission "*", "listen,resolve,connect";
    permission "jdk.jfr.FlightRecorderPermission" "accessFlightRecorder";
    permission "org.opensearch.secure_sm.ThreadPermission" "modifyArbitraryThreadGroup";
    permission "org.opensearch.secure_sm.ThreadPermission" "modifyArbitraryThread";
    permission "javax.management.MBeanServerPermission" "createMBeanServer";
    permission "javax.management.MBeanPermission" "*", "invoke,getAttribute";
    permission "java.io.FilePermission" "/var/tmp/killProfiler", "read";
};
